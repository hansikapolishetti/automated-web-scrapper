{
  "name": "automated-web-scrapper",
  "version": "1.0.0",
  "description": "Root package for managing frontend and Python backend.",
  "scripts": {
    "install:all": "npm install && npm install --prefix frontend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "py backend/server.py",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
